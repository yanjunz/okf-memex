# Raw sources — large files
raw/papers/*.pdf
raw/videos/*.mp4
raw/videos/*.mkv
raw/podcasts/*.mp3
raw/books/*.pdf
raw/books/*.epub

# Keep markdown/text sources
!raw/papers/*.md
!raw/videos/*.md
!raw/podcasts/*.md
!raw/books/*.md

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/
venv/

# Obsidian
# Use **/ so patterns match .obsidian/ inside any bundle dir (default wiki/, or a
# custom name from --bundle-name). Anchoring to the repo root would silently miss
# them because the vault is at <bundle>/.obsidian/, not repo-root/.obsidian/.
**/.obsidian/workspace*
**/.obsidian/cache
.thumbs/
# Symlinks inside the bundle dir that point into raw/ — created by init_wiki.py,
# don't track (bundle can be renamed, so use * prefix, not literal wiki/).
*/Clippings
*/Notes
